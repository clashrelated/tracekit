{
  "manifest_version": 3,
  "name": "TraceKit — Redirect & Affiliate Inspector",
  "short_name": "TraceKit",
  "version": "0.1.0",
  "description": "Reveal the full redirect chain behind any link. Spot affiliate networks, tracking params, and the real final URL — instantly.",
  "author": "TraceKit",
  "minimum_chrome_version": "114",

  "permissions": [
    "contextMenus",
    "storage",
    "scripting",
    "activeTab",
    "webRequest",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "popup/popup.html"
  },

  "action": {
    "default_title": "TraceKit",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
